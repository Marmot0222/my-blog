# 公网域名与 TLS；不要包含协议或路径。
DOMAIN=blog.example.com
ACME_EMAIL=admin@example.com

# 仅使用 URL 安全字符的随机强密码；DATABASE_URL 必须与下列三项完全一致。
POSTGRES_DB=ting_lab
POSTGRES_USER=ting_lab
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://ting_lab:replace-with-a-long-random-password@db:5432/ting_lab
DATABASE_POOL_MAX=10

# Chat：openai | openai-compatible | google
AI_PROVIDER=openai
AI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=replace-with-chat-api-key
# OPENAI_COMPATIBLE_API_KEY=replace-with-compatible-chat-api-key
# OPENAI_BASE_URL=https://provider.example/v1
# GOOGLE_GENERATIVE_AI_API_KEY=replace-with-google-api-key
AI_MAX_OUTPUT_TOKENS=1200
AI_REQUEST_TIMEOUT_MS=60000

# Embedding：openai | openai-compatible；模型必须支持输出 2048 维。
# OpenAI 会显式请求 2048 维；兼容接口必须由模型原生返回 2048 维。
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=2048
EMBEDDING_API_KEY=replace-with-embedding-api-key
# 仅自定义 Embedding 端点时设置：
# EMBEDDING_BASE_URL=https://provider.example/v1
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_RETRIES=2

RAG_TOP_K=6
RAG_SIMILARITY_THRESHOLD=0.55
RAG_MAX_CONTEXT_CHARS=12000

TRUST_PROXY=true
NEXT_PUBLIC_SITE_URL=https://blog.example.com
SKIP_CONTENT_INDEX=0
