# Chat 模型：openai | openai-compatible | google
AI_PROVIDER=openai
AI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# OpenAI-compatible Chat 示例（启用时将 AI_PROVIDER 改为 openai-compatible）
# OPENAI_COMPATIBLE_API_KEY=
# OPENAI_BASE_URL=https://your-provider.example/v1

AI_MAX_OUTPUT_TOKENS=1200
AI_REQUEST_TIMEOUT_MS=60000

DATABASE_URL=postgresql://ting_lab:change-me@localhost:5432/ting_lab
DATABASE_POOL_MAX=5
POSTGRES_DB=ting_lab
POSTGRES_USER=ting_lab
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# Embedding 与 Chat 独立配置。compatible 可复用上方 OPENAI_BASE_URL。
# 当前 pgvector schema 使用 halfvec(2048)，Embedding 模型必须支持该输出维度。
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=2048
EMBEDDING_API_KEY=
# 仅自定义 Embedding 端点时设置：
# EMBEDDING_BASE_URL=https://your-provider.example/v1
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_RETRIES=2

RAG_TOP_K=6
RAG_SIMILARITY_THRESHOLD=0.55
RAG_MAX_CONTEXT_CHARS=12000

# 仅当可信反向代理会覆盖客户端传入的 x-forwarded-for 时启用。
TRUST_PROXY=false
