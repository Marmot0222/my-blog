{
  "name": "ting-lab",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "content:check": "pnpm --filter @ting-lab/content content:check ../../content/posts",
    "content:index": "pnpm --filter @ting-lab/retrieval content:index ../../content/posts",
    "content:search": "pnpm --filter @ting-lab/retrieval content:search",
    "db:up": "docker compose --env-file apps/web/.env.local -f compose.dev.yml up -d",
    "db:down": "docker compose --env-file apps/web/.env.local -f compose.dev.yml down",
    "db:generate": "pnpm --filter @ting-lab/database db:generate",
    "db:migrate": "pnpm --filter @ting-lab/database db:migrate",
    "db:check": "pnpm --filter @ting-lab/database db:check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.5.8"
  }
}
